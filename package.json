{
  "name": "web-tools",
  "private": true,
  "version": "0.4.1",
  "description": "A monorepo dashboard for browser-based tools — built-in (Next.js routes) and external (git submodules).",
  "repository": {
    "type": "git",
    "url": "https://github.com/donjor/web-tools.git"
  },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:host": "bun run --filter @web-tools/host dev",
    "dev:noproxy": "bash scripts/dev-noproxy.sh",
    "build": "bash scripts/build.sh",
    "start": "bun run --filter @web-tools/host start",
    "typecheck": "bun run --filter '*' typecheck",
    "check": "bun run typecheck",
    "db:generate": "bun run --filter @web-tools/host db:generate",
    "db:migrate": "bun run --filter @web-tools/host db:migrate",
    "db:migrate:dev": "bun run --filter @web-tools/host db:migrate:dev",
    "db:status": "bun run --filter @web-tools/host db:status",
    "db:studio": "bun run --filter @web-tools/host db:studio",
    "db:reset": "bun run --filter @web-tools/host db:reset",
    "postinstall": "bash scripts/postinstall.sh",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/.next apps/external/*/node_modules packages/*/node_modules"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.10.0"
  },
  "packageManager": "bun@1.2.4"
}

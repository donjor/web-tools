# deps
node_modules/
.pnp.*
.yarn/

# build output
.next/
out/
dist/
build/
*.tsbuildinfo

# env
.env
.env.local
.env.*.local

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# bun
.bun/

# turbo / next cache
.turbo/
next-env.d.ts

# misc
.cache/
coverage/

# private host-specific runbook (IPs, internal hostnames, lab-only diffs)
# Copied between collaborator machines out-of-band — never committed.
/private/

# Prisma generated client (regenerated on install via postinstall)
apps/host/prisma/generated/

# Local SQLite (and any other dev-only data files) for built-in tools.
# The .data/ directory is committed (via .gitkeep) so the path exists on
# a fresh clone, but its contents are ignored.
apps/host/.data/*
!apps/host/.data/.gitkeep
